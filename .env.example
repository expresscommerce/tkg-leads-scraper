# Lead Scraper configuration — copy to `.env` and tweak.
# All variables are optional; sensible defaults are used otherwise.

# ── Meta Ad Library (direct scrape, no API) ──
META_ENABLED=1
META_AD_COUNTRY=US
META_HEADLESS=1
META_DELAY_SECONDS=2.0

# ── Google Maps ──
MAPS_HEADLESS=1
MAPS_MAX_SCROLLS=60

# ── Website enrichment ──
WEBSITE_MAX_WORKERS=6
WEBSITE_TIMEOUT=8

# ── Clay.com Owner-Email Enrichment ──
# Create a table in Clay UI with input columns: company_domain, company_name,
# first_name, last_name — and add your enrichment waterfall (Find Work Email etc.).
# Both keys must be set for Clay enrichment to activate.
CLAY_API_KEY=
CLAY_TABLE_ID=
CLAY_EMAIL_COLUMN=work_email      # name of the output column in your Clay table
CLAY_NAME_COLUMN=person_name      # name of the person-name output column (optional)
CLAY_POLL_TIMEOUT=90              # seconds to wait per row for enrichment
CLAY_DELAY_SECONDS=1.0            # pause between rows

# ── Output ──
OUTPUT_DIR=./output
LOG_LEVEL=INFO
DEBUG=0
