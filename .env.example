# Lead Scraper configuration — copy to `.env` and tweak.
# All variables are optional; sensible defaults are used otherwise.

# ── Meta Ad Library (direct scrape, no API) ──
META_ENABLED=1
META_AD_COUNTRY=US
META_HEADLESS=1
META_DELAY_SECONDS=2.0

# ── Google Maps ──
MAPS_HEADLESS=1
MAPS_MAX_SCROLLS=60

# ── Website enrichment ──
WEBSITE_MAX_WORKERS=6
WEBSITE_TIMEOUT=8

# ── Output ──
OUTPUT_DIR=./output
LOG_LEVEL=INFO
DEBUG=0
